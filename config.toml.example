# reorg-playground configuration file

database_path = "dbfile" # Database path of the key value store. Will be created if non-existing.
address = "0.0.0.0:2323" # Webserver listen address

# RSS feeds need a URL of the site. This is optional. If unset,
# the RSS feeds might not be valid according to the RSS 2.0 specification.
# Some RSS readers might complain.
rss_base_url = ""

[[networks]]
id = 0
name = "Mainnet"
description = "Bitcoin Mainnet"
query_interval = 15

first_tracked_height = 937000 # lower bound; loads from this height to tip into the db
visible_heights_from_tip = 500 # Base tip window size (heights counted backward from chain tip).
extra_hotspot_heights = 100 # Additional hotspot heights (fork/tip anchors) kept outside the base tip window.
network_type = "Mainnet" # Mainnet | Testnet | Signet | Regtest
view_only_mode = true # Disables node controls and the node connection manager.
stale_rate_windows = [100, 1000] # Rolling windows for stale-rate summary. Make sure to set first_tracked_height in approriately for this.
stale_rate_include_all_time = true

    [[networks.nodes]]
    id = 0
    name = "PublicNode"
    description = "Allnodes Bitcoin RPC node"
    rpc_host = "https://bitcoin-rpc.publicnode.com"
    rpc_port = 443
    rpc_user = ""
    rpc_password = ""
    use_rest = false
    client_implementation = "bitcoincore"

    [[networks.nodes]]
    id = 1
    name = "Electrum Emzy"
    description = "electrum.emzy.de:50002"
    rpc_host = "ssl://electrum.emzy.de"
    rpc_port = 50002
    client_implementation = "electrum"

[[networks]]
id = 1
name = "Testnet"
description = "Bitcoin Testnet"
query_interval = 15
first_tracked_height = 4841135
visible_heights_from_tip = 500
extra_hotspot_heights = 100
network_type = "Testnet"
view_only_mode = true # Disables node controls and the node connection manager.
stale_rate_windows = [100, 1000]
stale_rate_include_all_time = true

    [[networks.nodes]]
    id = 0
    name = "PublicNode"
    description = "Allnodes Bitcoin RPC node"
    rpc_host = "https://bitcoin-testnet-rpc.publicnode.com"
    rpc_port = 443
    rpc_user = ""
    rpc_password = ""
    use_rest = false
    client_implementation = "bitcoincore"


[[networks]]
id = 2
name = "Regtest"
description = "Bitcoin Regtest (local dev)"
query_interval = 1
first_tracked_height = 0
visible_heights_from_tip = 100
extra_hotspot_heights = 20
network_type = "Regtest"
view_only_mode = false # Only affects node controls on Regtest/custom Signet.
stale_rate_windows = [100, 1000]
stale_rate_include_all_time = true
# Note: You can deploy two local regtest nodes via scripts/start-regtest-nodes.sh, or use docker-compose.test-env.yml.

    [[networks.nodes]]
    id = 0
    name = "Node A"
    description = "Local Bitcoin Core node (regtest)"
    rpc_host = "127.0.0.1"
    rpc_port = 18443
    p2p_port = 18444 # P2P listening port. Enables to manage node connections via the UI.
    # rpc_cookie_file = ""
    rpc_user = "reorg-playground"
    rpc_password = "reorg-playground"
    use_rest = false
    client_implementation = "bitcoincore"
    supports_mining = true # Only has an effect on Regtest/Signet. On Signet, ensure the node has signing keys.

    [[networks.nodes]]
    id = 1
    name = "Node B"
    description = "Local Bitcoin Core node (regtest)"
    rpc_host = "127.0.0.1"
    rpc_port = 18453
    p2p_port = 18454 # P2P listening port. Enables to manage node connections via the UI.
    # rpc_cookie_file = ""
    rpc_user = "reorg-playground"
    rpc_password = "reorg-playground"
    use_rest = false
    client_implementation = "bitcoincore"
    supports_mining = true # Only has an effect on Regtest/Signet. On Signet, ensure the node has signing keys.

[[networks]]
id = 3
name = "Signet"
description = "Bitcoin Signet (local custom 3-node cluster)"
query_interval = 1
first_tracked_height = 0
visible_heights_from_tip = 100
extra_hotspot_heights = 20
network_type = "Signet"
signet_challenge = "5121031b14827738eaf41b67f50a2ddd9d0b08907236f3d0e79bef7fc9ea7b866a3ca821036739e2fc3681d2ef7f9afc0bb2f8964c4f61b6c30f4642cc0322e57967d31f3652ae" # Custom signet challenge script (hex). Must match the bitcoind -signetchallenge.
signet_nbits = "1e0377ae" # Custom signet mining difficulty target (hex). Passed to the signet miner.
view_only_mode = false # Enables app controls for Signet mining and P2P toggling.
stale_rate_windows = [100, 1000]
stale_rate_include_all_time = true
# Note: scripts/start-signet-nodes.sh boots Miner A, Miner B, and Observer C for the custom Signet cluster, or use docker-compose.test-env.yml.

    [[networks.nodes]]
    id = 0
    name = "Miner A"
    description = "Local Bitcoin Core node A (custom Signet miner)"
    rpc_host = "127.0.0.1"
    rpc_port = 38332
    p2p_port = 38333 # P2P listening port. Enables to manage node connections via the UI.
    # rpc_cookie_file = ""
    rpc_user = "reorg-playground"
    rpc_password = "reorg-playground"
    use_rest = false
    client_implementation = "bitcoincore"
    supports_mining = true # Only has an effect on Regtest/Signet. On Signet, ensure the node has signing keys.

    [[networks.nodes]]
    id = 1
    name = "Miner B"
    description = "Local Bitcoin Core node B (custom Signet miner)"
    rpc_host = "127.0.0.1"
    rpc_port = 39332
    p2p_port = 39333 # P2P listening port. Enables to manage node connections via the UI.
    # rpc_cookie_file = ""
    rpc_user = "reorg-playground"
    rpc_password = "reorg-playground"
    use_rest = false
    client_implementation = "bitcoincore"
    supports_mining = true # Only has an effect on Regtest/Signet. On Signet, ensure the node has signing keys.

    [[networks.nodes]]
    id = 2
    name = "Observer C"
    description = "Local Bitcoin Core node C (custom Signet observer)"
    rpc_host = "127.0.0.1"
    rpc_port = 40332
    p2p_port = 40333 # P2P listening port. Enables to manage node connections via the UI.
    # rpc_cookie_file = ""
    rpc_user = "reorg-playground"
    rpc_password = "reorg-playground"
    use_rest = false
    client_implementation = "bitcoincore"
    supports_mining = false # Only has an effect on Regtest/Signet. On Signet, ensure the node has signing keys.
